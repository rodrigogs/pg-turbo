{
  "name": "pg-turbo",
  "version": "0.1.0",
  "description": "Resilient PostgreSQL dump & restore with direct COPY protocol",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "pg-turbo": "./bin/pg-turbo.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx bin/pg-turbo.ts",
    "bench": "tsx bench/benchmark.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "commander": "^14.0.3",
    "log-update": "^7.2.0",
    "lz4": "^0.6.5",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "picocolors": "^1.1.1",
    "tar": "^7.5.13",
    "zstd-napi": "^0.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/lz4": "^0.6.4",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
