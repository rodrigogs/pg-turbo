{
  "name": "pg-resilient",
  "version": "0.1.0",
  "description": "Resilient PostgreSQL dump & restore with direct COPY protocol",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3",
    "log-update": "^7.2.0",
    "lz4": "^0.6.5",
    "nano-spawn": "^2.0.0",
    "nanospinner": "^1.2.2",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/lz4": "^0.6.4",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
